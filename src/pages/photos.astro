---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

function loadPhotos(): ImageMetadata[] {
  const imageModules = import.meta.glob(
    "../photos/**/*.{jpg,JPG}",
    { eager: true },
  ) as Record<string, { default: ImageMetadata }>;
  return Object.values(imageModules).map((img) => img.default);
}

const photos = loadPhotos();
---

<Layout title="photos">
  <p>here's some photos i've taken over the years! <a href="/">(back home)</a></p>

  <div class="gallery">
    {photos.map((photo) => <Image src={photo} alt="" />)}
  </div>
</Layout>

<style>
  body {
    margin-left: 10px;
  }

  .gallery {
    column-count: 1;
    column-gap: 8px;
  }

  .gallery img {
    width: 100%;
    height: auto;
    break-inside: avoid;
    display: block;
    margin-bottom: 8px;
  }

  @media (min-width: 480px) {
    .gallery {
      column-count: 2;
    }
  }

  @media (min-width: 760px) {
    .gallery {
      column-count: 3;
    }
  }

  @media (min-width: 1024px) {
    .gallery {
      column-count: 4;
    }
  }
</style>
